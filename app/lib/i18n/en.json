  "story": {
    "tag": "SINCE 2019",
    "eyebrow": "— OUR STORY",
    "titleLine1": "Not just décor.",
    "titleLine2": "A love letter to saltwater.",
    "p1": "Lightboard started in a garage two blocks from the beach. A surfboard, a string of fairy lights, three photos from a good day out — that first piece still hangs in our studio.",
    "p2": "Today we ship wall pieces for every kind of ride across Israel and beyond. The recipe hasn't changed: raw wood, careful hands, and a little bit of adventure in every grain.",
    "stats": [
      {"n": "6 YRS", "k": "crafting"},
      {"n": "2,400+", "k": "walls dressed"},
      {"n": "100%", "k": "handmade"}
    ]
  },
  "faq": {
    "eyebrow": "— FREQUENTLY ASKED",
    "titleLine1": "Before you",
    "titleLine2": "ask.",
    "items": [
      {
        "q": "How long will my order take?",
        "a": "Every Lightboard is built to order. Average turnaround from confirmation to your door is 10–14 business days — one studio, one pair of hands, no rushing the wall art."
      },
      {
        "q": "Can I order a custom size or finish?",
        "a": "Yes. Send us a note with the idea, the wall it's going on and the three shots you'd hang in it — we'll come back with a sketch and a quote within a few days."
      },
      {
        "q": "What is it made of?",
        "a": "Solid handworked pine, natural oil finish, low-power warm LEDs, and magnets that hold three 9×13 cm prints. No cheap plastic, no MDF."
      },
      {
        "q": "How do I care for it?",
        "a": "A soft dry cloth every couple of weeks and a spot out of direct sunlight. If something ever goes wrong — send us a photo and we'll make it right."
      },
      {
        "q": "What about returns?",
        "a": "Stock pieces: 14 days in new condition. Custom commissions are one-of-a-kind so they're not returnable, but we walk every order through to make sure it lands the way you imagined."
      }
    ]
  },
  "testify": {
    "eyebrow": "— WHAT PEOPLE SAY",
    "prev": "previous",
